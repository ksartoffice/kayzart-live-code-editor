{
  "name": "kayzart-live-code-editor",
  "version": "1.3.0",
  "description": "Live HTML/CSS/JS editor with a custom KayzArt post type, CodeMirror editor, and live preview.",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "version:set": "node scripts/version-set.mjs",
    "version:check": "node scripts/version-check.mjs",
    "dev": "vite",
    "build": "vite build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "plugin-zip": "npm run build && composer install --no-dev --optimize-autoloader && node scripts/plugin-zip.mjs && composer install",
    "e2e": "playwright test",
    "e2e:install": "playwright install"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.19.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@emmetio/codemirror6-plugin": "^0.4.0",
    "@wordpress/components": "^31.0.0",
    "@wordpress/element": "^6.37.0",
    "@wordpress/i18n": "^6.10.0",
    "@wordpress/icons": "^11.4.0",
    "codemirror": "^6.0.2",
    "lucide": "^0.563.0",
    "parse5": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@wordpress/scripts": "^31.3.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^16.6.1",
    "ignore": "^5.3.2",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
