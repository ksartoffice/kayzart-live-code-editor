<?xml version="1.0"?>
<ruleset name="KayzArt">
  <description>WordPress Coding Standards for KayzArt.</description>

  <config name="testVersion" value="7.4-"/>
  <arg name="extensions" value="php"/>

  <file>kayzart-live-code-editor.php</file>
  <file>includes</file>

  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>node_modules/*</exclude-pattern>
  <exclude-pattern>assets/*</exclude-pattern>
  <exclude-pattern>src/*</exclude-pattern>

  <rule ref="WordPress-Core"/>
  <rule ref="WordPress-Docs"/>
  <rule ref="WordPress-Extra"/>
  <rule ref="PHPCompatibilityWP"/>
  <rule ref="WordPress.Files.FileName">
    <properties>
      <property name="strict_class_file_names" value="false"/>
    </properties>
  </rule>

  <!--
    The pure AI edit tools intentionally have no WordPress dependencies so they
    stay unit-testable in isolation. Their exception messages are internal
    diagnostics serialized to JSON for the model, never echoed as HTML output,
    so the output-escaping sniff does not apply here.
  -->
  <rule ref="WordPress.Security.EscapeOutput">
    <exclude-pattern>includes/ai/class-kayzart-ai-tools.php</exclude-pattern>
  </rule>
</ruleset>


