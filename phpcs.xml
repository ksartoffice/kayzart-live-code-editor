<?xml version="1.0"?>
<ruleset name="KayzArt">
  <description>WordPress Coding Standards for KayzArt.</description>

  <config name="testVersion" value="7.4-"/>
  <arg name="extensions" value="php"/>

  <file>kayzart-live-code-editor.php</file>
  <file>includes</file>

  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>node_modules/*</exclude-pattern>
  <exclude-pattern>assets/*</exclude-pattern>
  <exclude-pattern>src/*</exclude-pattern>

  <rule ref="WordPress-Core"/>
  <rule ref="WordPress-Docs"/>
  <rule ref="WordPress-Extra"/>
  <rule ref="PHPCompatibilityWP"/>
  <rule ref="WordPress.Files.FileName">
    <properties>
      <property name="strict_class_file_names" value="false"/>
    </properties>
  </rule>

  <!--
    The AI service layer (includes/ai/) contains logic/service classes, not view
    output. Their exception messages are internal diagnostics that are serialized
    to JSON for the model or logged, never echoed as HTML, so the output-escaping
    sniff does not apply. HTML/REST output lives in includes/rest/ and remains
    covered by the sniff.
  -->
  <rule ref="WordPress.Security.EscapeOutput">
    <exclude-pattern>includes/ai/*</exclude-pattern>
  </rule>
</ruleset>


